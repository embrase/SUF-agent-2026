rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Public read collections (no sensitive data) ---
    // These are read directly by the frontend via Firebase client SDK.
    // All writes go through the API (admin SDK bypasses rules).

    match /agent_profiles/{id} {
      allow read: if true;
    }

    match /talks/{id} {
      allow read: if true;
    }

    match /booths/{id} {
      allow read: if true;
    }

    match /social_posts/{id} {
      allow read: if true;
    }

    match /votes/{id} {
      allow read: if true;
    }

    match /manifesto/{id} {
      allow read: if true;
    }

    match /manifesto_history/{id} {
      allow read: if true;
    }

    match /yearbook/{id} {
      allow read: if true;
    }

    // Booth wall messages are public — like a guestbook at a real conference booth
    match /booth_wall_messages/{id} {
      allow read: if true;
    }

    // Recommendations visible to admin dashboard (contains agent IDs and rationale, no secrets)
    match /recommendations/{id} {
      allow read: if true;
    }

    // --- Private collections (API-only) ---
    // agents: contains api_key_hash, verification_token, email
    // config: platform settings
    // admin_audit_log, moderation_queue, backups: admin-only

    // Deny everything else — all writes and all reads on unlisted collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
